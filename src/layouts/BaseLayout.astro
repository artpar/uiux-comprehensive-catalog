---
import "../styles/global.css";
import { withBase } from "@/lib/paths";
import { SITE_NAME } from "@/lib/seo";

type Props = {
  title: string;
  description?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
};

const {
  title,
  description = "A source-backed guide to practical UX and UI patterns.",
  structuredData
} = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalHref = new URL(currentPath, Astro.site ?? Astro.url).toString();
const sitemapHref = new URL(withBase("/sitemap.xml"), Astro.site ?? Astro.url).toString();
const jsonLd = structuredData ? JSON.stringify(structuredData).replaceAll("</script", "<\\/script") : undefined;
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID || "abacfae7-b939-4c0e-ae4b-fb950bba4b7f";
const umamiScriptUrl = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL || "https://cloud.umami.is/script.js";
const navItems = [
  { href: withBase("/"), label: "Home", icon: "#", active: currentPath === withBase("/") },
  { href: withBase("/patterns/"), label: "Patterns", icon: "A", active: currentPath.startsWith(withBase("/patterns/")) },
  { href: withBase("/resources/"), label: "Resources", icon: "::", active: currentPath.startsWith(withBase("/resources/")) },
  { href: withBase("/lab/"), label: "Lab", icon: "[]", active: currentPath.startsWith(withBase("/lab/")) },
  { href: withBase("/compare/"), label: "Compare", icon: "<>", active: currentPath.startsWith(withBase("/compare/")) },
  { href: withBase("/sources/"), label: "Sources", icon: "{}", active: currentPath.startsWith(withBase("/sources/")) },
  { href: withBase("/anti-patterns/"), label: "Anti-patterns", icon: "!", active: currentPath.startsWith(withBase("/anti-patterns/")) },
  { href: withBase("/agent/"), label: "Agent exports", icon: "->", active: currentPath.startsWith(withBase("/agent/")) }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="msvalidate.01" content="BD93A582145D3C26A00A7FB4FDE65BE5" />
    <meta name="naver-site-verification" content="da84aabacd3ceabd6ab1f06a452ee49de25539f7" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalHref} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href={withBase("/favicon.ico")} sizes="any" />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <link rel="icon" href={withBase("/favicon-32x32.png")} type="image/png" sizes="32x32" />
    <link rel="icon" href={withBase("/favicon-48x48.png")} type="image/png" sizes="48x48" />
    <link rel="apple-touch-icon" href={withBase("/apple-touch-icon.png")} sizes="180x180" />
    <link rel="canonical" href={canonicalHref} />
    <link rel="sitemap" href={sitemapHref} type="application/xml" />
    <title>{title}</title>
    {jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd} />}
    {import.meta.env.PROD && umamiWebsiteId && (
      <>
        <script is:inline>
          document.addEventListener("click", function(event) {
            var target = event.target instanceof Element ? event.target.closest("[data-analytics-event]") : null;
            if (!target || !window.umami || typeof window.umami.track !== "function") return;
            var props = {};
            for (var key in target.dataset) {
              if (key === "analyticsEvent") continue;
              props[key] = target.dataset[key];
            }
            window.umami.track(target.dataset.analyticsEvent, Object.keys(props).length ? props : undefined);
          });
        </script>
        <script is:inline data-umami-src={umamiScriptUrl} data-umami-id={umamiWebsiteId}>
          (function() {
            var currentScript = document.currentScript;
            var src = currentScript && currentScript.dataset.umamiSrc;
            var websiteId = currentScript && currentScript.dataset.umamiId;
            if (!src || !websiteId) return;

            function loadUmami() {
              if (document.querySelector('script[data-website-id="' + websiteId + '"]')) return;
              var script = document.createElement("script");
              script.defer = true;
              script.src = src;
              script.dataset.websiteId = websiteId;
              document.head.appendChild(script);
            }

            window.addEventListener("load", function() {
              if ("requestIdleCallback" in window) {
                window.requestIdleCallback(loadUmami, { timeout: 3000 });
              } else {
                window.setTimeout(loadUmami, 1500);
              }
            }, { once: true });
          })();
        </script>
      </>
    )}
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase("/")}>UX Patterns Guide</a>
      <nav aria-label="Primary">
        {navItems.map((item) => (
          <a href={item.href} aria-current={item.active ? "page" : undefined}>
            <span class="nav-mark" aria-hidden="true">{item.icon}</span>
            {item.label}
          </a>
        ))}
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
