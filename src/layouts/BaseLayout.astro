---
import "../styles/global.css";
import { withBase } from "@/lib/paths";
import { SITE_NAME } from "@/lib/seo";

type Props = {
  title: string;
  description?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
};

const {
  title,
  description = "A source-backed guide to practical UX and UI patterns.",
  structuredData
} = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalHref = new URL(currentPath, Astro.site ?? Astro.url).toString();
const sitemapHref = new URL(withBase("/sitemap.xml"), Astro.site ?? Astro.url).toString();
const jsonLd = structuredData ? JSON.stringify(structuredData).replaceAll("</script", "<\\/script") : undefined;
const navItems = [
  { href: withBase("/"), label: "Home", icon: "#", active: currentPath === withBase("/") },
  { href: withBase("/patterns/"), label: "Patterns", icon: "A", active: currentPath.startsWith(withBase("/patterns/")) },
  { href: withBase("/lab/"), label: "Lab", icon: "[]", active: currentPath.startsWith(withBase("/lab/")) },
  { href: withBase("/compare/"), label: "Compare", icon: "<>", active: currentPath.startsWith(withBase("/compare/")) },
  { href: withBase("/sources/"), label: "Sources", icon: "{}", active: currentPath.startsWith(withBase("/sources/")) },
  { href: withBase("/anti-patterns/"), label: "Anti-patterns", icon: "!", active: currentPath.startsWith(withBase("/anti-patterns/")) },
  { href: withBase("/agent/"), label: "Agent exports", icon: "->", active: currentPath.startsWith(withBase("/agent/")) }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="msvalidate.01" content="BD93A582145D3C26A00A7FB4FDE65BE5" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalHref} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <link rel="canonical" href={canonicalHref} />
    <link rel="sitemap" href={sitemapHref} type="application/xml" />
    <title>{title}</title>
    {jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd} />}
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase("/")}>UX Patterns Guide</a>
      <nav aria-label="Primary">
        {navItems.map((item) => (
          <a href={item.href} aria-current={item.active ? "page" : undefined}>
            <span class="nav-mark" aria-hidden="true">{item.icon}</span>
            {item.label}
          </a>
        ))}
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
