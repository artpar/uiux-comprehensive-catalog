---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/lib/paths";
---

<BaseLayout title="Agent Exports | UI/UX Pattern Catalog">
  <section class="page-head">
    <h1>Agent exports</h1>
    <p>
      Static context files for LLM agents that need to choose better UI/UX patterns before generating
      code. These files are generated from validated pattern data during the build.
    </p>
  </section>

  <section class="detail-panel">
    <h2>Prompt-ready Markdown</h2>
    <ul>
      <li><a href={withBase("/agent/patterns.md")}>Pattern guidance</a></li>
      <li><a href={withBase("/agent/decision-guide.md")}>Decision guide</a></li>
      <li><a href={withBase("/agent/anti-pattern-checklist.md")}>Anti-pattern checklist</a></li>
    </ul>
  </section>

  <section class="detail-panel">
    <h2>Machine-readable JSON</h2>
    <ul>
      <li><a href={withBase("/agent/patterns.json")}>Compact pattern JSON</a></li>
    </ul>
  </section>
</BaseLayout>
