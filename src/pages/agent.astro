---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { patterns } from "@/lib/catalog";
import { withBase } from "@/lib/paths";
import { breadcrumbJsonLd, collectionPageJsonLd, pageTitle } from "@/lib/seo";

const completePatterns = patterns.filter((pattern) => pattern.completionStatus === "complete");
const stubCount = patterns.length - completePatterns.length;
const featuredPatterns = completePatterns.slice(0, 4);
const patternBrief = featuredPatterns
  .map((pattern) => [
    `Pattern: ${pattern.name}`,
    `Use when: ${pattern.selectionRules[0]}`,
    `Must include: ${pattern.requiredStates.slice(0, 2).join("; ")}`,
    `Avoid: ${pattern.commonMisuses[0]}`
  ].join("\n"))
  .join("\n\n") || "No patterns are currently marked complete. Stub entries are excluded from agent-ready guidance.";

const decisionBrief = [
  "Before generating UI:",
  "1. Identify user job, consequence severity, reversibility, platform, and interruption cost.",
  "2. Choose the pattern whose required states and interaction contract match that context.",
  "3. Reject patterns whose avoid-when rules or common misuses match the current flow.",
  "4. Generate the required empty, loading, error, disabled, keyboard, and recovery states."
].join("\n");

const antiPatternBrief = patterns
  .filter((pattern) => pattern.completionStatus === "complete" && pattern.maturity === "anti-pattern")
  .map((pattern) => [
    `Anti-pattern: ${pattern.name}`,
    `Detect: ${pattern.problemContext[0]}`,
    `Replace with: ${pattern.implementationChecklist[0]}`,
    `Review: ${pattern.critiqueQuestions[0]}`
  ].join("\n"))
  .join("\n\n") || "No anti-patterns are currently marked complete. Stub entries are excluded from this checklist.";
const siteUrl = Astro.site ?? new URL("https://uxpatternsguide.com");
const description = "Download machine-readable UX pattern guidance for agents that need source-backed interaction contracts before generating UI.";
---

<BaseLayout
  title={pageTitle("UX Pattern Agent Exports")}
  description={description}
  structuredData={[
    collectionPageJsonLd("UX Pattern Agent Exports", description, "/agent/", siteUrl),
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Agent exports", path: "/agent/" }
    ], siteUrl)
  ]}
>
  <nav class="breadcrumb-trail" aria-label="Breadcrumb">
    <a href={withBase("/")}>Home</a>
    <span aria-current="page">Agent exports</span>
  </nav>

  <section class="page-head">
    <h1>Agent exports</h1>
    <p>
      Static context files for LLM agents that need to choose better UI/UX patterns before generating
      code. These files are generated from validated pattern data during the build.
    </p>
    <p>{completePatterns.length} complete patterns exported. {stubCount} stub entries excluded.</p>
  </section>

  <div class="agent-export-grid">
    <section class="detail-panel export-card">
      <div class="decision-card-head">
        <h2>Pattern Guidance</h2>
        <button class="demo-button small" data-copy-target="pattern-guidance">Copy preview</button>
      </div>
      <p>Use before code generation when an agent needs pattern contracts and common mistakes.</p>
      <textarea id="pattern-guidance" name="pattern-guidance" readonly rows="10">{patternBrief}</textarea>
      <a class="action-link" href={withBase("/agent/patterns.md")}>Open full Markdown</a>
    </section>

    <section class="detail-panel export-card">
      <div class="decision-card-head">
        <h2>Decision Guide</h2>
        <button class="demo-button small" data-copy-target="decision-guide">Copy preview</button>
      </div>
      <p>Use when the agent must choose between patterns from task risk and state requirements.</p>
      <textarea id="decision-guide" name="decision-guide" readonly rows="10">{decisionBrief}</textarea>
      <a class="action-link" href={withBase("/agent/decision-guide.md")}>Open full Markdown</a>
    </section>

    <section class="detail-panel export-card">
      <div class="decision-card-head">
        <h2>Anti-pattern Checklist</h2>
        <button class="demo-button small" data-copy-target="anti-pattern-checklist">Copy preview</button>
      </div>
      <p>Use after generation or during review to find known interaction failures and safer replacements.</p>
      <textarea id="anti-pattern-checklist" name="anti-pattern-checklist" readonly rows="10">{antiPatternBrief}</textarea>
      <a class="action-link" href={withBase("/agent/anti-pattern-checklist.md")}>Open full Markdown</a>
    </section>

    <section class="detail-panel export-card">
      <h2>Machine-readable JSON</h2>
      <p>Use for retrieval, custom agents, or automated catalog checks.</p>
      <dl class="export-shape">
        <div><dt>patterns[].selectionRules</dt><dd>Candidate choice rules.</dd></div>
        <div><dt>patterns[].requiredStates</dt><dd>States the generated UI must include.</dd></div>
        <div><dt>patterns[].commonMisuses</dt><dd>What not to generate.</dd></div>
      </dl>
      <a class="action-link" href={withBase("/agent/patterns.json")}>Open JSON</a>
    </section>
  </div>

  <script>
    document.querySelectorAll("[data-copy-target]").forEach((button) => {
      button.addEventListener("click", async () => {
        const target = document.getElementById(button.getAttribute("data-copy-target") || "");
        if (!(target instanceof HTMLTextAreaElement)) return;
        await navigator.clipboard.writeText(target.value);
        button.textContent = "Copied";
        window.setTimeout(() => {
          button.textContent = "Copy preview";
        }, 1400);
      });
    });
  </script>
</BaseLayout>
