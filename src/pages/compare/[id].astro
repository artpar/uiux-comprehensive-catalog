---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { comparisons, getPattern, getSource } from "@/lib/catalog";
import { withBase } from "@/lib/paths";
import type { PatternEntry } from "@/schemas/catalog";

function isPattern(value: PatternEntry | undefined): value is PatternEntry {
  return Boolean(value);
}

function formatPatternType(value: PatternEntry["patternType"]) {
  if (value === "ui") return "UI";
  if (value === "ux") return "UX";
  return "UI + UX";
}

export function getStaticPaths() {
  return comparisons.map((comparison) => ({
    params: { id: comparison.id },
    props: { comparison }
  }));
}

const { comparison } = Astro.props;
const comparedPatterns = comparison.patternIds.map((id) => getPattern(id)).filter(isPattern);
const sourceRefs = comparison.sources.map((ref) => ({ ref, source: getSource(ref.id) }));
const dimensions = [
  {
    label: "UI or UX",
    value: (pattern: PatternEntry) => `${formatPatternType(pattern.patternType)} - ${pattern.surfaceType}`
  },
  {
    label: "UI guidance",
    value: (pattern: PatternEntry) => pattern.uiGuidance[0]
  },
  {
    label: "UX guidance",
    value: (pattern: PatternEntry) => pattern.uxGuidance[0]
  },
  {
    label: "Good UI",
    value: (pattern: PatternEntry) => pattern.uiExamples.good[0]
  },
  {
    label: "Bad UI",
    value: (pattern: PatternEntry) => pattern.uiExamples.bad[0]
  },
  {
    label: "Good UX",
    value: (pattern: PatternEntry) => pattern.uxExamples.good[0]
  },
  {
    label: "Bad UX",
    value: (pattern: PatternEntry) => pattern.uxExamples.bad[0]
  },
  {
    label: "Best fit",
    value: (pattern: PatternEntry) => pattern.useWhen[0] ?? pattern.selectionRules[0]
  },
  {
    label: "Avoid when",
    value: (pattern: PatternEntry) => pattern.avoidWhen[0] ?? pattern.failureModes[0]
  },
  {
    label: "Required state",
    value: (pattern: PatternEntry) => pattern.requiredStates[0]
  },
  {
    label: "Accessibility burden",
    value: (pattern: PatternEntry) => pattern.accessibility[0] ?? pattern.keyboardBehavior[0] ?? "Verify focus, labels, and operable controls."
  },
  {
    label: "Common misuse",
    value: (pattern: PatternEntry) => pattern.commonMisuses[0]
  }
];
---

<BaseLayout title={`${comparison.title} | UI/UX Pattern Catalog`} description={comparison.summary}>
  <section class="compare-detail-head">
    <a class="open-link" href={withBase("/compare/")}>Back to compare picker</a>
    <h1>{comparedPatterns.map((pattern) => pattern.name).join(" vs ")}</h1>
    <p>{comparison.decisionRules[0]}</p>
    <div class="comparison-links">
      {comparedPatterns.map((pattern) => (
        <a data-live-pattern={pattern.id} href={withBase(`/?pattern=${pattern.id}`)}>{pattern.name} live example</a>
      ))}
    </div>
  </section>

  <section class="detail-panel context-panel" id="workbench-context" hidden>
    <h2>Workbench Context</h2>
    <dl class="context-list">
      <div><dt>Selected</dt><dd data-context-value="selected"></dd></div>
      <div><dt>Shortlist</dt><dd data-context-value="shortlist"></dd></div>
      <div><dt>User job</dt><dd data-context-value="job"></dd></div>
      <div><dt>Search</dt><dd data-context-value="query"></dd></div>
      <div><dt>Mode</dt><dd data-context-value="mode"></dd></div>
      <div><dt>Category</dt><dd data-context-value="category"></dd></div>
      <div><dt>Platform</dt><dd data-context-value="platform"></dd></div>
      <div><dt>Maturity</dt><dd data-context-value="maturity"></dd></div>
      <div><dt>Risk</dt><dd data-context-value="risk"></dd></div>
      <div><dt>Recovery</dt><dd data-context-value="recovery"></dd></div>
      <div><dt>Urgency</dt><dd data-context-value="urgency"></dd></div>
      <div><dt>Confidence</dt><dd data-context-value="confidence"></dd></div>
      <div><dt>Interruption</dt><dd data-context-value="interruption"></dd></div>
    </dl>
  </section>

  <section class="comparison-matrix detail-panel compare-decision-table">
    <h2>Decision dimensions</h2>
    <table>
      <thead>
        <tr>
          <th>Dimension</th>
          {comparedPatterns.map((pattern) => <th>{pattern.name}</th>)}
        </tr>
      </thead>
      <tbody>
        {dimensions.map((dimension) => (
          <tr>
            <th scope="row">{dimension.label}</th>
            {comparedPatterns.map((pattern) => <td>{dimension.value(pattern)}</td>)}
          </tr>
        ))}
      </tbody>
    </table>
    <div class="compare-mobile-cards" aria-label="Decision dimensions by pattern">
      {comparedPatterns.map((pattern) => (
        <article>
          <h3>{pattern.name}</h3>
          <dl>
            {dimensions.map((dimension) => (
              <div>
                <dt>{dimension.label}</dt>
                <dd>{dimension.value(pattern)}</dd>
              </div>
            ))}
          </dl>
        </article>
      ))}
    </div>
  </section>

  <div class="detail-grid">
    <div class="stack">
      <details class="detail-panel compact-disclosure" open>
        <summary>Decision rules</summary>
        <ul>
          {comparison.decisionRules.map((item) => <li>{item}</li>)}
        </ul>
      </details>

      <details class="detail-panel compact-disclosure">
        <summary>Inspect live examples</summary>
        <div class="comparison-links">
          {comparedPatterns.map((pattern) => (
            <a data-live-pattern={pattern.id} href={withBase(`/?pattern=${pattern.id}`)}>{pattern.name}</a>
          ))}
        </div>
      </details>

      {comparison.failureModes.length > 0 && (
        <details class="detail-panel compact-disclosure">
          <summary>Failure modes</summary>
          <ul>
            {comparison.failureModes.map((item) => <li>{item}</li>)}
          </ul>
        </details>
      )}
    </div>

    <aside class="stack">
      <details class="detail-panel compact-disclosure">
        <summary>Sources</summary>
        <ul>
          {sourceRefs.map(({ ref, source }) => (
            <li>
              {source ? <a href={withBase(`/sources/${source.id}/`)}>{source.name}</a> : ref.id}
              <br />
              <span>{ref.note}</span>
            </li>
          ))}
        </ul>
      </details>

      <section class="detail-panel compact-note">
        <h2>Verification</h2>
        <p>Last verified: {comparison.lastVerified}</p>
      </section>
    </aside>
  </div>

  <script>
    const contextPanel = document.getElementById("workbench-context");
    const params = new URLSearchParams(window.location.search);
    const contextKeys = [
      "selected",
      "shortlist",
      "job",
      "query",
      "mode",
      "category",
      "platform",
      "maturity",
      "risk",
      "recovery",
      "urgency",
      "confidence",
      "interruption"
    ];
    const hasContext = contextKeys.some((key) => params.has(key));

    if (contextPanel && hasContext) {
      contextPanel.hidden = false;
      contextKeys.forEach((key) => {
        const target = contextPanel.querySelector(`[data-context-value="${key}"]`);
        if (!target) return;
        target.textContent = params.get(key)?.replaceAll(",", ", ") || "Not set";
      });
    }

    document.querySelectorAll("[data-live-pattern]").forEach((link) => {
      if (!(link instanceof HTMLAnchorElement)) return;
      const pattern = link.getAttribute("data-live-pattern");
      const nextParams = new URLSearchParams(window.location.search);
      nextParams.delete("selected");
      if (pattern) nextParams.set("pattern", pattern);
      link.href = `${link.pathname}?${nextParams.toString()}`;
    });
  </script>
</BaseLayout>
