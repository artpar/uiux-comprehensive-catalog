---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { comparisons, patterns, getPattern } from "@/lib/catalog";
import { withBase } from "@/lib/paths";
import { breadcrumbJsonLd, collectionPageJsonLd, pageTitle } from "@/lib/seo";
import { patternCategories } from "@/schemas/catalog";

const patternOptions = patterns
  .filter((pattern) => pattern.maturity !== "anti-pattern")
  .map((pattern) => ({ id: pattern.id, name: pattern.name }))
  .sort((a, b) => a.name.localeCompare(b.name));
const comparisonOptions = comparisons.map((comparison) => {
  const comparedPatterns = comparison.patternIds.map((id) => getPattern(id)).filter(Boolean);
  const categories = [
    ...new Set(
      comparedPatterns
        .flatMap((pattern) => [pattern?.category, ...(pattern?.secondaryCategories ?? [])])
        .filter(Boolean)
    )
  ];
  return {
    id: comparison.id,
    title: comparison.title,
    href: withBase(`/compare/${comparison.id}/`),
    patternIds: comparison.patternIds,
    patternNames: comparedPatterns.map((pattern) => pattern?.name ?? "").filter(Boolean),
    categories,
    primaryCategory: categories[0] ?? "Other",
    summary: comparison.summary,
    rule: comparison.decisionRules[0],
    lastVerified: comparison.lastVerified
  };
});
const categoryGroups = patternCategories
  .map((category) => ({
    category,
    comparisons: comparisonOptions.filter((comparison) => comparison.primaryCategory === category)
  }))
  .filter((group) => group.comparisons.length > 0);
const categoryFilters = patternCategories
  .map((category) => ({
    category,
    count: comparisonOptions.filter((comparison) => comparison.primaryCategory === category).length
  }))
  .filter((item) => item.count > 0);
const siteUrl = Astro.site ?? new URL("https://uxpatternsguide.com");
const description = "Compare UX and UI patterns side by side before choosing an interaction model for a product workflow.";
---

<BaseLayout
  title={pageTitle("UX Pattern Comparisons")}
  description={description}
  structuredData={[
    collectionPageJsonLd("UX Pattern Comparisons", description, "/compare/", siteUrl),
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Comparisons", path: "/compare/" }
    ], siteUrl)
  ]}
>
  <div class="compare-home">
    <nav class="breadcrumb-trail" aria-label="Breadcrumb">
      <a href={withBase("/")}>Home</a>
      <span aria-current="page">Comparisons</span>
    </nav>

    <section class="compare-hero" aria-labelledby="compare-title">
      <div class="compare-intro">
        <div class="pattern-kicker">
          <span>{comparisonOptions.length} comparisons</span>
          <span>{categoryFilters.length} families</span>
          <span>Decision rules</span>
        </div>
        <h1 id="compare-title">Choose the right pattern before you build</h1>
        <p>{description}</p>
        <div class="decision-track-grid compare-principles">
          <span><strong>Compare fit</strong> Similar-looking UI can carry different task costs.</span>
          <span><strong>Check failure</strong> Every comparison names misuse and avoid-when conditions.</span>
          <span><strong>Open lab</strong> Inspect states before committing to a pattern.</span>
        </div>
      </div>

      <form class="compare-form" data-compare-form>
        <h2>Find a supported pair</h2>
        <label>
          <span>First pattern</span>
          <select name="first">
            <option value="">Choose pattern</option>
            {patternOptions.map((pattern) => <option value={pattern.id}>{pattern.name}</option>)}
          </select>
        </label>

        <label>
          <span>Second pattern</span>
          <select name="second">
            <option value="">Choose pattern</option>
            {patternOptions.map((pattern) => <option value={pattern.id}>{pattern.name}</option>)}
          </select>
        </label>

        <a class="demo-button primary compare-open is-disabled" data-compare-open href="#" aria-disabled="true">
          Open comparison
        </a>
        <p class="demo-status" data-compare-status>Choose a supported pair to compare.</p>
      </form>
    </section>

    <section class="compare-browse" aria-labelledby="available-comparisons">
      <div class="compare-browse-head">
        <div class="section-heading">
          <span>{comparisonOptions.length} comparisons</span>
          <h2 id="available-comparisons">Browse by product decision</h2>
          <p>Use search when you know the pattern name; use categories when you know the workflow area.</p>
        </div>
        <label class="compare-search">
          <span>Search comparisons</span>
          <input data-compare-search type="search" placeholder="Search by pattern, category, or decision rule" />
        </label>
      </div>

      <label class="compare-category-select">
        <span>Category</span>
        <select data-compare-category-select>
          <option value="all">All categories ({comparisonOptions.length})</option>
          {categoryFilters.map((item) => <option value={item.category}>{item.category} ({item.count})</option>)}
        </select>
      </label>

      <p class="compare-result-count" data-compare-result-count>{comparisonOptions.length} comparisons shown</p>
      <p class="compare-empty" data-compare-empty hidden>No comparisons match this filter.</p>

      <div class="comparison-library">
        {categoryGroups.map((group) => (
          <section class="comparison-category-section" data-category-section={group.category}>
            <div class="comparison-category-head">
              <h3>{group.category}</h3>
              <span>{group.comparisons.length}</span>
            </div>
            <div class="comparison-list-grid">
              {group.comparisons.map((comparison) => (
                <a
                  class="comparison-row"
                  href={comparison.href}
                  data-compare-card
                  data-primary-category={comparison.primaryCategory}
                  data-categories={comparison.categories.join("|")}
                  data-search={[
                    comparison.title,
                    comparison.summary,
                    comparison.rule,
                    comparison.patternNames.join(" "),
                    comparison.categories.join(" ")
                  ].join(" ").toLowerCase()}
                >
                  <span>{comparison.patternNames.join(" vs ")}</span>
                  <strong>{comparison.rule}</strong>
                  <div class="comparison-row-meta">
                    <small>{comparison.patternNames.length} patterns</small>
                    <small>{comparison.primaryCategory}</small>
                    <small>Verified {comparison.lastVerified}</small>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ comparisonOptions }}>
    const comparisons = comparisonOptions;
    const form = document.querySelector("[data-compare-form]");
    const openLink = document.querySelector("[data-compare-open]");
    const status = document.querySelector("[data-compare-status]");
    const search = document.querySelector("[data-compare-search]");
    const categorySelect = document.querySelector("[data-compare-category-select]");
    const categoryButtons = [...document.querySelectorAll("[data-compare-category]")];
    const cards = [...document.querySelectorAll("[data-compare-card]")];
    const sections = [...document.querySelectorAll("[data-category-section]")];
    const resultCount = document.querySelector("[data-compare-result-count]");
    const empty = document.querySelector("[data-compare-empty]");
    let activeCategory = "all";

    function updateCompareLink() {
      if (!(form instanceof HTMLFormElement) || !(openLink instanceof HTMLAnchorElement) || !status) return;
      const data = new FormData(form);
      const first = String(data.get("first") || "");
      const second = String(data.get("second") || "");
      const selected = [first, second].filter(Boolean).sort().join("|");
      const match = comparisons.find((comparison) => [...comparison.patternIds].sort().join("|") === selected);

      if (!first || !second) {
        openLink.href = "#";
        openLink.classList.add("is-disabled");
        openLink.setAttribute("aria-disabled", "true");
        status.textContent = "Choose a supported pair to compare.";
        return;
      }

      if (!match || first === second) {
        openLink.href = "#";
        openLink.classList.add("is-disabled");
        openLink.setAttribute("aria-disabled", "true");
        status.textContent = "No comparison page exists for that pair yet.";
        return;
      }

      openLink.href = match.href;
      openLink.classList.remove("is-disabled");
      openLink.removeAttribute("aria-disabled");
      status.textContent = match.title;
    }

    form?.addEventListener("change", updateCompareLink);
    openLink?.addEventListener("click", (event) => {
      if (openLink.getAttribute("aria-disabled") === "true") event.preventDefault();
    });

    function updateLibraryFilter() {
      const query = search instanceof HTMLInputElement ? search.value.trim().toLowerCase() : "";
      let visibleCount = 0;

      cards.forEach((card) => {
        const primaryCategory = String(card.getAttribute("data-primary-category") || "");
        const searchText = String(card.getAttribute("data-search") || "");
        const matchesCategory = activeCategory === "all" || primaryCategory === activeCategory;
        const matchesSearch = !query || searchText.includes(query);
        const isVisible = matchesCategory && matchesSearch;
        card.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
      });

      sections.forEach((section) => {
        const hasVisibleCard = Boolean(section.querySelector("[data-compare-card]:not([hidden])"));
        section.hidden = !hasVisibleCard;
      });

      categoryButtons.forEach((button) => {
        button.classList.toggle("is-active", button.getAttribute("data-compare-category") === activeCategory);
      });
      if (categorySelect instanceof HTMLSelectElement) categorySelect.value = activeCategory;

      if (resultCount) {
        resultCount.textContent = `${visibleCount} ${visibleCount === 1 ? "comparison" : "comparisons"} shown`;
      }
      if (empty) empty.hidden = visibleCount > 0;
    }

    search?.addEventListener("input", updateLibraryFilter);
    categorySelect?.addEventListener("change", () => {
      activeCategory = categorySelect instanceof HTMLSelectElement ? categorySelect.value : "all";
      updateLibraryFilter();
    });
    categoryButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeCategory = button.getAttribute("data-compare-category") || "all";
        updateLibraryFilter();
      });
    });
  </script>
</BaseLayout>
