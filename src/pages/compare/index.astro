---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { comparisons } from "@/lib/catalog";
import { withBase } from "@/lib/paths";
---

<BaseLayout title="Pattern Comparisons | UI/UX Pattern Catalog">
  <section class="page-head">
    <h1>Pattern comparisons</h1>
    <p>Decision pages for choosing between similar interaction patterns.</p>
  </section>

  <div class="pattern-grid">
    {comparisons.map((comparison) => (
      <article class="comparison-card">
        <h2><a href={withBase(`/compare/${comparison.id}/`)}>{comparison.title}</a></h2>
        <p>{comparison.summary}</p>
      </article>
    ))}
  </div>
</BaseLayout>
