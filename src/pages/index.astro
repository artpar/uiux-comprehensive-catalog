---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { comparisons, patterns, sources } from "@/lib/catalog";
import { withBase } from "@/lib/paths";

const completePatterns = patterns.filter((pattern) => pattern.completionStatus === "complete");
const antiPatternCount = patterns.filter((pattern) => pattern.maturity === "anti-pattern").length;
const categoryDescriptions: Record<string, string> = {
  "AI And Automation UX": "Patterns for prompts, agent plans, transparency, approval, and AI output review.",
  "Collaboration And Social Interaction": "Patterns for comments, mentions, presence, feeds, handoffs, and shared work.",
  "Cross-Device And Physical Interaction": "Patterns for touch, sensors, device permissions, haptics, camera, and offline use.",
  "Data Display And Exploration": "Patterns for tables, dashboards, charts, maps, timelines, and drill-down views.",
  "Disclosure And Attention Management": "Patterns for revealing detail, focusing attention, and keeping context stable.",
  "Error Prevention And Recovery": "Patterns for preventing mistakes, explaining failure, retrying, undoing, and restoring work.",
  "Feedback, Status, And System State": "Patterns for loading, progress, alerts, banners, notifications, and system confidence.",
  "Input And Data Entry": "Patterns for forms, fields, validation, uploads, dates, addresses, payments, and account data.",
  "Navigation And Wayfinding": "Patterns for moving through pages, sections, steps, breadcrumbs, menus, and local hierarchy.",
  "Personalization And Preference": "Patterns for defaults, settings, preferences, saved views, recommendations, and user control.",
  "Search, Browse, And Discovery": "Patterns for search, filters, categories, suggestions, empty results, and saved retrieval.",
  "Selection And Choice": "Patterns for choosing values, commands, objects, options, ranges, and contextual actions.",
  "Task And Workflow Patterns": "Patterns for staged tasks, approvals, review, scheduling, checkout, and multi-step work.",
  "Trust, Safety, And Privacy": "Patterns for consent, warnings, privacy, security, permissions, reporting, and sensitive data."
};
const categoryGroups = [...new Set(patterns.map((pattern) => pattern.category))]
  .sort()
  .map((category) => {
    const categoryPatterns = patterns.filter((pattern) => pattern.category === category);
    return {
      category,
      completeCount: categoryPatterns.filter((pattern) => pattern.completionStatus === "complete").length,
      totalCount: categoryPatterns.length,
      description: categoryDescriptions[category],
      sample: categoryPatterns.find((pattern) => pattern.completionStatus === "complete") ?? categoryPatterns[0]
    };
  });
const featuredPatterns = completePatterns
  .filter((pattern) => pattern.maturity !== "anti-pattern")
  .slice(0, 6);
const searchPayload = patterns.map((pattern) => ({
  id: pattern.id,
  name: pattern.name,
  category: pattern.category,
  surfaceType: pattern.surfaceType,
  problem: pattern.problem,
  useWhen: pattern.useWhen[0] ?? pattern.selectionRules[0] ?? pattern.problem,
  href: withBase(`/patterns/${pattern.id}/`)
}));

function slugify(value: string) {
  return value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
}

function categoryHref(category: string) {
  return withBase(`/patterns/#${slugify(category)}`);
}

function labCategoryHref(category: string) {
  return withBase(`/lab/?category=${encodeURIComponent(category)}`);
}
---

<BaseLayout
  title="UX Patterns Guide"
  description="A source-backed guide to practical UX and UI patterns with an interactive lab for choosing the right pattern."
>
  <section class="catalog-home" aria-labelledby="catalog-title">
    <div class="catalog-intro">
      <p class="eyebrow">UX patterns guide</p>
      <h1 id="catalog-title">Find the right pattern.</h1>
      <p>
        Browse practical interface patterns by family, read the decision rule, then open the lab when you need
        filtering, comparison, live examples, and implementation checks.
      </p>
    </div>

    <form class="catalog-search" role="search" data-catalog-search>
      <label for="catalog-query">Search patterns</label>
      <div class="catalog-search-row">
        <input
          id="catalog-query"
          name="query"
          type="search"
          autocomplete="off"
          placeholder="Try error recovery, navigation, filters, AI"
          data-catalog-query
        />
        <a href={withBase("/patterns/")}>All patterns</a>
      </div>
      <div class="catalog-search-results" data-catalog-results hidden></div>
    </form>

    <dl class="catalog-stats" aria-label="Catalog status">
      <div>
        <dt>{patterns.length}</dt>
        <dd>pattern entries</dd>
      </div>
      <div>
        <dt>{completePatterns.length}</dt>
        <dd>complete patterns</dd>
      </div>
      <div>
        <dt>{comparisons.length}</dt>
        <dd>comparisons</dd>
      </div>
      <div>
        <dt>{sources.length}</dt>
        <dd>evidence sources</dd>
      </div>
    </dl>
  </section>

  <section class="catalog-section" aria-labelledby="subject-title">
    <div class="section-heading">
      <h2 id="subject-title">Pattern families</h2>
      <p>Start from the user problem, not from a component name.</p>
    </div>
    <div class="category-index">
      {categoryGroups.map((group) => (
        <article class="category-row">
          <a href={categoryHref(group.category)}>
            <span>{group.category}</span>
            <strong>{group.totalCount} entries</strong>
          </a>
          <p>{group.description ?? group.sample?.useWhen[0] ?? group.sample?.problem}</p>
          <a class="quiet-link" href={labCategoryHref(group.category)}>Open in lab</a>
        </article>
      ))}
    </div>
  </section>

  <section class="catalog-section catalog-two-column" aria-labelledby="featured-title">
    <div>
      <div class="section-heading">
        <h2 id="featured-title">Readable entries</h2>
        <p>Each entry explains when to use it, when to avoid it, what states are required, and what sources back the guidance.</p>
      </div>
      <div class="featured-list">
        {featuredPatterns.map((pattern) => (
          <article class="featured-row">
            <h3><a href={withBase(`/patterns/${pattern.id}/`)}>{pattern.name}</a></h3>
            <p>{pattern.useWhen[0]}</p>
            <span>{pattern.category}</span>
          </article>
        ))}
      </div>
    </div>

    <aside class="lab-invite" aria-labelledby="lab-title">
      <p class="eyebrow">Interactive lab</p>
      <h2 id="lab-title">Use the workbench when the choice is not obvious.</h2>
      <p>
        Filter by job, category, platform, maturity, risk, reversibility, urgency, confidence, and interruption cost.
        Compare alternatives and inspect live examples without losing the readable catalog.
      </p>
      <div class="lab-invite-actions">
        <a class="primary-action" href={withBase("/lab/")}>Open lab</a>
        <a class="secondary-action" href={withBase("/compare/")}>Compare patterns</a>
      </div>
      <dl>
        <div><dt>{antiPatternCount}</dt><dd>anti-pattern checks</dd></div>
        <div><dt>{completePatterns.length}</dt><dd>ready for implementation review</dd></div>
      </dl>
    </aside>
  </section>

  <section class="catalog-section email-strip" aria-labelledby="email-title">
    <div>
      <p class="eyebrow">Email</p>
      <h2 id="email-title">One practical pattern at a time.</h2>
    </div>
    <p>
      The newsletter belongs after the catalog path: a concise pattern brief for teams that want sharper
      implementation and review language.
    </p>
    <a href="mailto:artpar@gmail.com?subject=Subscribe%20to%20UI%2FUX%20Pattern%20Catalog">Subscribe</a>
  </section>

  <script is:inline type="application/json" id="catalog-search-data" set:html={JSON.stringify(searchPayload)} />
  <script>
    type SearchPattern = {
      id: string;
      name: string;
      category: string;
      surfaceType: string;
      problem: string;
      useWhen: string;
      href: string;
    };

    const searchScript = document.getElementById("catalog-search-data");
    const searchInput = document.querySelector("[data-catalog-query]");
    const searchResults = document.querySelector("[data-catalog-results]");
    const searchForm = document.querySelector("[data-catalog-search]");
    const patterns = JSON.parse(searchScript?.textContent || "[]") as SearchPattern[];

    function normalize(value: string) {
      return value.toLowerCase().replace(/[^a-z0-9]+/g, " ").trim();
    }

    function renderSearch(query: string) {
      if (!(searchResults instanceof HTMLElement)) return;
      const terms = normalize(query).split(" ").filter(Boolean);
      searchResults.replaceChildren();

      if (terms.length === 0) {
        searchResults.hidden = true;
        return;
      }

      const matches = patterns
        .map((pattern) => {
          const text = normalize([
            pattern.name,
            pattern.category,
            pattern.surfaceType,
            pattern.problem,
            pattern.useWhen
          ].join(" "));
          const score = terms.reduce((total, term) => total + (text.includes(term) ? 1 : 0), 0);
          return { pattern, score };
        })
        .filter((item) => item.score > 0)
        .sort((a, b) => b.score - a.score || a.pattern.name.localeCompare(b.pattern.name))
        .slice(0, 8);

      const status = document.createElement("p");
      status.className = "catalog-result-status";
      status.textContent = matches.length ? `${matches.length} matches` : "No matching patterns";
      searchResults.append(status);

      for (const { pattern } of matches) {
        const link = document.createElement("a");
        link.href = pattern.href;
        const name = document.createElement("strong");
        name.textContent = pattern.name;
        const meta = document.createElement("span");
        meta.textContent = pattern.category;
        const summary = document.createElement("small");
        summary.textContent = pattern.useWhen || pattern.problem;
        link.append(name, meta, summary);
        searchResults.append(link);
      }

      searchResults.hidden = false;
    }

    if (searchInput instanceof HTMLInputElement) {
      searchInput.addEventListener("input", () => renderSearch(searchInput.value));
    }

    if (searchForm instanceof HTMLFormElement) {
      searchForm.addEventListener("submit", (event) => {
        event.preventDefault();
        renderSearch(searchInput instanceof HTMLInputElement ? searchInput.value : "");
      });
    }
  </script>
</BaseLayout>
