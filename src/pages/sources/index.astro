---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPatternsForSource, sources } from "@/lib/catalog";
import { withBase } from "@/lib/paths";
import { breadcrumbJsonLd, collectionPageJsonLd, pageTitle } from "@/lib/seo";

const authorityByType: Record<string, string> = {
  spec: "Normative accessibility and semantics evidence",
  "platform-guideline": "Platform behavior and convention evidence",
  "ux-research": "Research-backed interaction guidance",
  "service-manual": "Task completion and public-service evidence",
  "product-example": "Observed product implementation evidence",
  "hci-literature": "Academic interaction evidence",
  "pattern-library": "Pattern inventory evidence"
};
const sourceTypes = [...new Set(sources.map((source) => source.type))].sort();
const linkedPatternCount = new Set(sources.flatMap((source) => getPatternsForSource(source.id).map((pattern) => pattern.id))).size;
const siteUrl = Astro.site ?? new URL("https://uxpatternsguide.com");
const description = "Browse the specs, research, service manuals, product examples, and pattern libraries that support UX Patterns Guide.";
---

<BaseLayout
  title={pageTitle("UX Pattern Sources")}
  description={description}
  structuredData={[
    collectionPageJsonLd("UX Pattern Sources", description, "/sources/", siteUrl),
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Sources", path: "/sources/" }
    ], siteUrl)
  ]}
>
  <nav class="breadcrumb-trail" aria-label="Breadcrumb">
    <a href={withBase("/")}>Home</a>
    <span aria-current="page">Sources</span>
  </nav>

  <section class="pattern-directory-hero source-index-hero">
    <div>
      <div class="pattern-kicker">
        <span>{sources.length} sources</span>
        <span>{sourceTypes.length} evidence types</span>
        <span>{linkedPatternCount} linked patterns</span>
      </div>
      <h1>Source index</h1>
      <p>Every accepted pattern is tied back to specs, platform guidance, UX research, service manuals, or real product evidence.</p>
      <div class="pattern-hero-actions">
        <a class="primary-action" href="#evidence-weight">Review evidence weight</a>
        <a class="secondary-action" href="#source-list">Browse sources</a>
      </div>
    </div>
    <aside class="source-method-panel">
      <h2>How to read sources</h2>
      <p>Sources validate decision rules, behavior contracts, accessibility expectations, and failure risks. They are not treated as visual style templates.</p>
    </aside>
  </section>

  <section class="comparison-matrix detail-panel evidence-weight-panel" id="evidence-weight">
    <h2>Evidence Weight</h2>
    <table>
      <thead>
        <tr>
          <th>Source type</th>
          <th>How to use it</th>
          <th>Current coverage</th>
        </tr>
      </thead>
      <tbody>
        {sourceTypes.map((type) => {
          const typeSources = sources.filter((source) => source.type === type);
          const linkedPatternCount = new Set(typeSources.flatMap((source) => getPatternsForSource(source.id).map((pattern) => pattern.id))).size;
          return (
            <tr>
              <th scope="row">{type}</th>
              <td data-label="How to use it">{authorityByType[type] ?? "Supporting evidence"}</td>
              <td data-label="Current coverage">{typeSources.length} sources backing {linkedPatternCount} patterns</td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </section>

  <div class="source-list" id="source-list">
    {sourceTypes.map((type) => (
      <section class="source-group">
        <h2>{type}</h2>
        {sources.filter((source) => source.type === type).map((source) => {
          const linkedPatterns = getPatternsForSource(source.id);
          return (
            <article class="source-row">
              <h3><a href={withBase(`/sources/${source.id}/`)}>{source.name}</a></h3>
              <div class="pill-list">
                <span>{linkedPatterns.length} patterns</span>
                <span>checked {source.checkedAt}</span>
              </div>
              <p>{source.notes}</p>
            </article>
          );
        })}
      </section>
    ))}
  </div>
</BaseLayout>
