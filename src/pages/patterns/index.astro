---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { patterns } from "@/lib/catalog";
import { withBase } from "@/lib/paths";
import { breadcrumbJsonLd, collectionPageJsonLd, pageTitle } from "@/lib/seo";

const categoryDescriptions: Record<string, string> = {
  "AI And Automation UX": "AI capability boundaries, agent control, source grounding, uncertainty, approval, and safe fallback.",
  "Collaboration And Social Interaction": "Comments, mentions, presence, feeds, handoffs, shared attention, and team workflow.",
  "Cross-Device And Physical Interaction": "Touch, haptics, sensors, camera, permissions, offline states, and device adaptation.",
  "Data Display And Exploration": "Tables, dashboards, charts, maps, compare views, timelines, and drill-down behavior.",
  "Disclosure And Attention Management": "Progressive disclosure, overlays, warnings, focus, and interruption management.",
  "Error Prevention And Recovery": "Validation, undo, retry, fallback, destructive action review, and recovery paths.",
  "Feedback, Status, And System State": "Loading, progress, alerts, banners, sync, confidence, and system visibility.",
  "Input And Data Entry": "Forms, field behavior, uploads, dates, addresses, payment entry, and account data.",
  "Navigation And Wayfinding": "Headers, breadcrumbs, tabs, side navigation, steps, local anchors, and return paths.",
  "Personalization And Preference": "Settings, preference centers, saved views, defaults, recommendations, and user control.",
  "Search, Browse, And Discovery": "Search, filters, facets, category browsing, query correction, and no-results recovery.",
  "Selection And Choice": "Choice controls, object pickers, ranges, menu actions, bulk selection, and commands.",
  "Task And Workflow Patterns": "Multi-step work, approvals, scheduling, review queues, checkout, and task completion.",
  "Trust, Safety, And Privacy": "Consent, privacy, security, sensitive data, reporting, permissions, and safety exits."
};
const groupedPatterns = [...new Set(patterns.map((pattern) => pattern.category))]
  .sort()
  .map((category) => ({
    category,
    patterns: patterns
      .filter((pattern) => pattern.category === category)
      .sort((a, b) => a.name.localeCompare(b.name))
  }));
const completeCount = patterns.filter((pattern) => pattern.completionStatus === "complete").length;
const sourceClaimCount = patterns.reduce((total, pattern) => total + pattern.sources.length, 0);
function slugify(value: string) {
  return value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
}

const siteUrl = Astro.site ?? new URL("https://uxpatternsguide.com");
const description = "Browse practical UX and UI patterns by family, with source-backed guidance, implementation checks, and live examples.";
---

<BaseLayout
  title={pageTitle("UX and UI Patterns")}
  description={description}
  structuredData={[
    collectionPageJsonLd("UX and UI Patterns", description, "/patterns/", siteUrl),
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Patterns", path: "/patterns/" }
    ], siteUrl)
  ]}
>
  <nav class="breadcrumb-trail" aria-label="Breadcrumb">
    <a href={withBase("/")}>Home</a>
    <span aria-current="page">Patterns</span>
  </nav>

  <section class="pattern-directory-hero" aria-labelledby="patterns-title">
    <div>
      <div class="pattern-kicker">
        <span>{patterns.length} patterns</span>
        <span>{completeCount} complete</span>
        <span>{sourceClaimCount} source claims</span>
      </div>
      <h1 id="patterns-title">Pattern directory</h1>
      <p>{description}</p>
      <div class="pattern-hero-actions">
        <a class="primary-action" href={withBase("/lab/")}>Open interactive lab</a>
        <a class="secondary-action" href={withBase("/compare/")}>Compare alternatives</a>
      </div>
    </div>

    <form class="catalog-search pattern-directory-search" role="search" data-pattern-index-search data-search-index-url={withBase("/pattern-search.json")}>
      <label for="pattern-index-query">Search by problem, state, or pattern name</label>
      <div class="catalog-search-row">
        <input
          id="pattern-index-query"
          name="query"
          type="search"
          autocomplete="off"
          placeholder="Try empty state, AI approval"
          data-pattern-index-query
        />
        <button type="submit">Search</button>
      </div>
      <div class="catalog-search-results" data-pattern-index-results hidden></div>
    </form>
  </section>

  <div class="pattern-directory-layout">
    <nav class="letter-nav category-jump" aria-label="Jump to pattern family">
      {groupedPatterns.map((group) => (
        <a href={`#${slugify(group.category)}`}>{group.category}</a>
      ))}
    </nav>

    <div class="pattern-index">
      {groupedPatterns.map((group) => (
        <section class="pattern-index-group" id={slugify(group.category)} aria-labelledby={`${slugify(group.category)}-title`}>
          <div class="pattern-index-group-head">
            <div>
              <h2 id={`${slugify(group.category)}-title`}>{group.category}</h2>
              <p>{categoryDescriptions[group.category]}</p>
            </div>
            <span>{group.patterns.length} entries</span>
          </div>
          <div class="catalog-card-grid">
            {group.patterns.map((pattern) => (
              <article
                class="catalog-card pattern-index-card"
                data-pattern-index-card
                data-pattern-id={pattern.id}
                data-category={pattern.category}
              >
                <h3><a href={withBase(`/patterns/${pattern.id}/`)}>{pattern.name}</a></h3>
                <p>{pattern.useWhen[0] ?? pattern.problem}</p>
                <dl class="pattern-card-facts">
                  <div><dt>Type</dt><dd>{pattern.patternType.toUpperCase()}</dd></div>
                  <div><dt>Sources</dt><dd>{pattern.sources.length}</dd></div>
                  <div><dt>Verified</dt><dd>{pattern.lastVerified}</dd></div>
                </dl>
                <div class="pill-list">
                  <span>{pattern.maturity}</span>
                  <span>{pattern.completionStatus}</span>
                </div>
                <a class="quiet-link" href={withBase(`/lab/?pattern=${pattern.id}`)}>Open in lab</a>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
  <script>
    type PatternSearchEntry = {
      id: string;
      name: string;
      category: string;
      maturity: string;
      surfaceType: string;
      problem: string;
      useWhen: string;
      href: string;
      searchText: string;
    };

    const patternSearchInput = document.querySelector("[data-pattern-index-query]");
    const patternSearchResults = document.querySelector("[data-pattern-index-results]");
    const patternSearchForm = document.querySelector("[data-pattern-index-search]");
    const patternCards = [...document.querySelectorAll("[data-pattern-index-card]")];
    const patternSections = [...document.querySelectorAll(".pattern-index-group")];
    let patternSearchDataPromise: Promise<PatternSearchEntry[]> | undefined;

    function getPatternSearchData() {
      if (patternSearchDataPromise) return patternSearchDataPromise;
      const url = patternSearchForm instanceof HTMLElement ? patternSearchForm.dataset.searchIndexUrl : undefined;
      patternSearchDataPromise = fetch(url || "/pattern-search.json")
        .then((response) => (response.ok ? response.json() : []))
        .catch(() => []) as Promise<PatternSearchEntry[]>;
      return patternSearchDataPromise;
    }

    function normalizePatternSearch(value: string) {
      return value.toLowerCase().replace(/[^a-z0-9]+/g, " ").trim();
    }

    async function renderPatternSearch(query: string) {
      const terms = normalizePatternSearch(query).split(" ").filter(Boolean);
      if (patternSearchResults instanceof HTMLElement) patternSearchResults.replaceChildren();

      if (terms.length === 0) {
        for (const card of patternCards) {
          if (card instanceof HTMLElement) card.hidden = false;
        }

        for (const section of patternSections) {
          if (section instanceof HTMLElement) section.hidden = false;
        }

        if (patternSearchResults instanceof HTMLElement) patternSearchResults.hidden = true;
        return;
      }

      const patternSearchData = await getPatternSearchData();
      const visiblePatternIds = new Set(
        patternSearchData
          .filter((pattern) => terms.every((term) => normalizePatternSearch(pattern.searchText || "").includes(term)))
          .map((pattern) => pattern.id)
      );

      for (const card of patternCards) {
        if (!(card instanceof HTMLElement)) continue;
        card.hidden = !visiblePatternIds.has(card.dataset.patternId || "");
      }

      for (const section of patternSections) {
        if (!(section instanceof HTMLElement)) continue;
        const visibleCards = section.querySelectorAll("[data-pattern-index-card]:not([hidden])");
        section.hidden = visibleCards.length === 0;
      }

      if (!(patternSearchResults instanceof HTMLElement)) return;

      const matches = patternSearchData
        .map((pattern) => {
          const text = normalizePatternSearch(pattern.searchText || [pattern.name, pattern.category, pattern.maturity, pattern.surfaceType, pattern.problem, pattern.useWhen].join(" "));
          const score = terms.reduce((total, term) => total + (text.includes(term) ? 1 : 0), 0);
          return { pattern, score };
        })
        .filter((item) => item.score > 0)
        .sort((a, b) => b.score - a.score || a.pattern.name.localeCompare(b.pattern.name))
        .slice(0, 8);

      const status = document.createElement("p");
      status.className = "catalog-result-status";
      status.textContent = matches.length ? `${matches.length} matching patterns` : "No matching patterns";
      patternSearchResults.append(status);

      for (const { pattern } of matches) {
        const link = document.createElement("a");
        link.href = pattern.href;
        const name = document.createElement("strong");
        name.textContent = pattern.name;
        const meta = document.createElement("span");
        meta.textContent = `${pattern.category} - ${pattern.maturity}`;
        const summary = document.createElement("small");
        summary.textContent = pattern.useWhen || pattern.problem;
        link.append(name, meta, summary);
        patternSearchResults.append(link);
      }

      patternSearchResults.hidden = false;
    }

    if (patternSearchInput instanceof HTMLInputElement) {
      patternSearchInput.addEventListener("input", () => renderPatternSearch(patternSearchInput.value));
    }

    if (patternSearchForm instanceof HTMLFormElement) {
      patternSearchForm.addEventListener("submit", (event) => {
        event.preventDefault();
        renderPatternSearch(patternSearchInput instanceof HTMLInputElement ? patternSearchInput.value : "");
      });
    }
  </script>
</BaseLayout>
