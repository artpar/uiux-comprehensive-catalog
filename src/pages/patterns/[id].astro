---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PatternPlayground from "@/components/PatternPlayground";
import { comparisons, getComparison, getPattern, getSource, patterns } from "@/lib/catalog";
import { withBase } from "@/lib/paths";
import { absoluteUrl, breadcrumbJsonLd, pageTitle, SITE_NAME } from "@/lib/seo";
import type { ComparisonEntry, PatternEntry } from "@/schemas/catalog";

function isPattern(value: PatternEntry | undefined): value is PatternEntry {
  return Boolean(value);
}

function isComparison(value: ComparisonEntry | undefined): value is ComparisonEntry {
  return Boolean(value);
}

function formatPatternType(value: PatternEntry["patternType"]) {
  if (value === "ui") return "UI";
  if (value === "ux") return "UX";
  return "UI + UX";
}

export function getStaticPaths() {
  return patterns.map((pattern) => ({
    params: { id: pattern.id },
    props: { pattern }
  }));
}

const { pattern } = Astro.props;
const sourceRefs = pattern.sources.map((ref) => ({ ref, source: getSource(ref.id) }));
const related = pattern.relatedPatterns.map((id) => getPattern(id)).filter(isPattern);
const patternComparisons = pattern.comparisons.map((id) => getComparison(id)).filter(isComparison);
const referencedByComparisons = comparisons.filter((comparison) => comparison.patternIds.includes(pattern.id));
const allComparisons = [...new Map([...patternComparisons, ...referencedByComparisons].map((item) => [item.id, item])).values()];
const siteUrl = Astro.site ?? new URL("https://uxpatternsguide.com");
const patternKind = pattern.maturity === "anti-pattern" ? "UX Anti-pattern" : "UX Pattern";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    headline: `${pattern.name} ${patternKind}`,
    name: pattern.name,
    description: pattern.problem,
    url: absoluteUrl(`/patterns/${pattern.id}/`, siteUrl),
    dateModified: pattern.lastVerified,
    inLanguage: "en",
    about: [pattern.category, pattern.surfaceType, ...pattern.aliases],
    citation: sourceRefs
      .map(({ source }) => source?.url)
      .filter(Boolean),
    isPartOf: {
      "@type": "WebSite",
      name: SITE_NAME,
      url: absoluteUrl("/", siteUrl)
    },
    publisher: {
      "@type": "Organization",
      name: SITE_NAME,
      url: absoluteUrl("/", siteUrl)
    }
  },
  breadcrumbJsonLd([
    { name: "Home", path: "/" },
    { name: "Patterns", path: "/patterns/" },
    { name: pattern.name, path: `/patterns/${pattern.id}/` }
  ], siteUrl)
];
---

<BaseLayout title={pageTitle(`${pattern.name} ${patternKind}`)} description={pattern.problem} structuredData={structuredData}>
  <nav class="breadcrumb-trail" aria-label="Breadcrumb">
    <a href={withBase("/")}>Home</a>
    <a href={withBase("/patterns/")}>Patterns</a>
    <span aria-current="page">{pattern.name}</span>
  </nav>

  <section class="pattern-titlebar">
    <div>
      <div class="pill-list">
        <span>{formatPatternType(pattern.patternType)}</span>
        <span>{pattern.surfaceType}</span>
        <span>{pattern.category}</span>
        <span>{pattern.maturity}</span>
        <span>{pattern.completionStatus}</span>
        {pattern.platforms.map((platform) => <span>{platform}</span>)}
      </div>
      <h1>{pattern.name}</h1>
      <p>{pattern.problem}</p>
    </div>
    <div class="title-actions">
      <a class="action-link" href={withBase(`/lab/?pattern=${pattern.id}`)}>Open in lab</a>
      {allComparisons[0] && <a class="action-link" href={withBase(`/compare/${allComparisons[0].id}/`)}>Compare alternatives</a>}
    </div>
  </section>

  <div class="pattern-lab">
    <PatternPlayground client:load pattern={pattern} variant="detail" />
  </div>

  <div class="pattern-workspace">
    <aside class="sticky-demo pattern-sidebar">
      <section class="detail-panel compact-panel">
        <h2>Decision Snapshot</h2>
        <p><strong>Type:</strong> {formatPatternType(pattern.patternType)} - {pattern.surfaceType}</p>
        <p><strong>Status:</strong> {pattern.completionStatus}</p>
        <p><strong>Verified:</strong> <time datetime={pattern.lastVerified}>{pattern.lastVerified}</time></p>
        <p><strong>Sources:</strong> {pattern.sources.length} source-backed claims</p>
        {pattern.completionNotes && (
          <details class="mini-disclosure">
            <summary>Catalog note</summary>
            <p>{pattern.completionNotes}</p>
          </details>
        )}
      </section>

      <details class="detail-panel compact-panel sidebar-disclosure agent-panel">
        <summary>Agent Contract</summary>
        <h3>Must include</h3>
        <ul>
          {pattern.requiredStates.slice(0, 3).map((item) => <li>{item}</li>)}
        </ul>
        <h3>Avoid Generating</h3>
        <ul>
          {pattern.commonMisuses.slice(0, 2).map((item) => <li>{item}</li>)}
        </ul>
      </details>

      {related.length > 0 && (
        <section class="detail-panel compact-panel">
          <h2>Related</h2>
          <ul>
            {related.map((item) => (
              <li><a href={withBase(`/patterns/${item.id}/`)}>{item.name}</a></li>
            ))}
          </ul>
        </section>
      )}

      {allComparisons.length > 0 && (
        <details class="detail-panel compact-panel sidebar-disclosure">
          <summary>Comparisons</summary>
          <ul>
            {allComparisons.map((item) => (
              <li><a href={withBase(`/compare/${item.id}/`)}>{item.title}</a></li>
            ))}
          </ul>
        </details>
      )}
    </aside>

    <div class="pattern-reading">
      <section class="pattern-brief" aria-labelledby="pattern-brief-heading">
        <div class="section-heading">
          <span>Quick read</span>
          <h2 id="pattern-brief-heading">What this pattern is for</h2>
        </div>
        <div class="pattern-brief-grid">
          <article class="reading-card strong-card">
            <span>Problem</span>
            <p>{pattern.problem}</p>
          </article>
          <article class="reading-card strong-card">
            <span>Better approach</span>
            <p>{pattern.solution}</p>
          </article>
          <article class="reading-card">
            <span>Use when</span>
            <p>{pattern.useWhen[0]}</p>
          </article>
          <article class="reading-card">
            <span>Avoid when</span>
            <p>{pattern.avoidWhen[0]}</p>
          </article>
        </div>
      </section>

      <section class="pattern-reading-section" aria-labelledby="pattern-quality-heading">
        <div class="section-heading">
          <span>UI and UX split</span>
          <h2 id="pattern-quality-heading">How to judge the result</h2>
        </div>
        <div class="pattern-quality-grid">
          <article class="reading-card quality-card">
            <h3>UI</h3>
            <p>What the user sees, scans, and manipulates.</p>
            <h4>Good signs</h4>
            <ul>
              {pattern.uiExamples.good.slice(0, 2).map((item) => <li>{item}</li>)}
            </ul>
            <h4>Warning signs</h4>
            <ul>
              {pattern.uiExamples.bad.slice(0, 2).map((item) => <li>{item}</li>)}
            </ul>
            <details class="mini-disclosure">
              <summary>More UI guidance</summary>
              <ul>
                {pattern.uiGuidance.map((item) => <li>{item}</li>)}
              </ul>
            </details>
          </article>
          <article class="reading-card quality-card">
            <h3>UX</h3>
            <p>How the interaction helps the user finish the task.</p>
            <h4>Good signs</h4>
            <ul>
              {pattern.uxExamples.good.slice(0, 2).map((item) => <li>{item}</li>)}
            </ul>
            <h4>Warning signs</h4>
            <ul>
              {pattern.uxExamples.bad.slice(0, 2).map((item) => <li>{item}</li>)}
            </ul>
            <details class="mini-disclosure">
              <summary>More UX guidance</summary>
              <ul>
                {pattern.uxGuidance.map((item) => <li>{item}</li>)}
              </ul>
            </details>
          </article>
        </div>
      </section>

      <section class="pattern-reading-section" aria-labelledby="implementation-heading">
        <div class="section-heading">
          <span>Build checklist</span>
          <h2 id="implementation-heading">What the implementation must handle</h2>
        </div>
        <div class="implementation-card-grid">
          <article class="reading-card">
            <span>Required states</span>
            <ul>
              {pattern.requiredStates.slice(0, 3).map((item) => <li>{item}</li>)}
            </ul>
          </article>
          <article class="reading-card">
            <span>Interaction contract</span>
            <ul>
              {pattern.interactionContract.slice(0, 3).map((item) => <li>{item}</li>)}
            </ul>
          </article>
          <article class="reading-card">
            <span>Common mistakes</span>
            <ul>
              {pattern.commonMisuses.slice(0, 3).map((item) => <li>{item}</li>)}
            </ul>
          </article>
          <article class="reading-card">
            <span>Critique questions</span>
            <ul>
              {pattern.critiqueQuestions.slice(0, 3).map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
      </section>

      <details class="guidance-block guidance-details agent-panel">
        <summary>Full agent/debug reference</summary>
        <h3>Problem Context</h3>
        <ul>
          {pattern.problemContext.map((item) => <li>{item}</li>)}
        </ul>

        <h3>Selection Rules</h3>
        <ul>
          {pattern.selectionRules.map((item) => <li>{item}</li>)}
        </ul>

        <h3>Required States</h3>
        <ul>
          {pattern.requiredStates.map((item) => <li>{item}</li>)}
        </ul>

        <h3>Interaction Contract</h3>
        <ul>
          {pattern.interactionContract.map((item) => <li>{item}</li>)}
        </ul>

        <h3>Implementation Checklist</h3>
        <ul>
          {pattern.implementationChecklist.map((item) => <li>{item}</li>)}
        </ul>

        <h3>Common Generated-UI Mistakes</h3>
        <ul>
          {pattern.commonMisuses.map((item) => <li>{item}</li>)}
        </ul>

        <h3>Critique Questions</h3>
        <ul>
          {pattern.critiqueQuestions.map((item) => <li>{item}</li>)}
        </ul>
      </details>

      <section class="reference-grid" aria-label="Pattern reference">
        <details class="guidance-block guidance-details">
          <summary>Use When</summary>
          <ul>
            {pattern.useWhen.map((item) => <li>{item}</li>)}
          </ul>
        </details>

        <details class="guidance-block guidance-details">
          <summary>Avoid When</summary>
          <ul>
            {pattern.avoidWhen.map((item) => <li>{item}</li>)}
          </ul>
        </details>

        {pattern.failureModes.length > 0 && (
          <details class="guidance-block guidance-details">
            <summary>Failure Modes</summary>
            <ul>
              {pattern.failureModes.map((item) => <li>{item}</li>)}
            </ul>
          </details>
        )}

        {pattern.accessibility.length > 0 && (
          <details class="guidance-block guidance-details">
            <summary>Accessibility</summary>
            <ul>
              {pattern.accessibility.map((item) => <li>{item}</li>)}
            </ul>
          </details>
        )}

        {pattern.keyboardBehavior.length > 0 && (
          <details class="guidance-block guidance-details">
            <summary>Keyboard Behavior</summary>
            <ul>
              {pattern.keyboardBehavior.map((item) => <li>{item}</li>)}
            </ul>
          </details>
        )}

        <details class="guidance-block guidance-details">
          <summary>Aliases</summary>
          <div class="pill-list">
            {pattern.aliases.length ? pattern.aliases.map((alias) => <span>{alias}</span>) : <span>None</span>}
          </div>
        </details>

        {pattern.variants.length > 0 && (
          <details class="guidance-block guidance-details">
            <summary>Variants</summary>
            <ul>
              {pattern.variants.map((item) => <li>{item}</li>)}
            </ul>
          </details>
        )}

        <details class="guidance-block guidance-details">
          <summary>Sources</summary>
          <ul>
            {sourceRefs.map(({ ref, source }) => (
              <li>
                {source ? <a href={withBase(`/sources/${source.id}/`)}>{source.name}</a> : ref.id}
                <br />
                <span>{ref.note}</span>
              </li>
            ))}
          </ul>
        </details>

        <section class="guidance-block verification-strip">
          <h2>Verification</h2>
          <p>Last verified: <time datetime={pattern.lastVerified}>{pattern.lastVerified}</time></p>
        </section>
      </section>
    </div>
  </div>
</BaseLayout>
