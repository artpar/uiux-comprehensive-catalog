---
import CatalogWorkbenchLoader from "@/components/CatalogWorkbenchLoader";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/lib/paths";
import { breadcrumbJsonLd, collectionPageJsonLd, pageTitle } from "@/lib/seo";

const siteUrl = Astro.site ?? new URL("https://uxpatternsguide.com");
const description = "Use the interactive UX pattern lab to filter source-backed patterns by product problem, platform, risk, and implementation state.";
---

<BaseLayout
  title={pageTitle("UX Pattern Lab")}
  description={description}
  structuredData={[
    collectionPageJsonLd("UX Pattern Lab", description, "/lab/", siteUrl),
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Pattern Lab", path: "/lab/" }
    ], siteUrl)
  ]}
>
  <nav class="breadcrumb-trail" aria-label="Breadcrumb">
    <a href={withBase("/")}>Home</a>
    <span aria-current="page">Pattern Lab</span>
  </nav>

  <header class="pattern-directory-hero lab-page-head">
    <div>
      <div class="pattern-kicker">
        <span>Interactive catalog</span>
        <span>State inspection</span>
        <span>Decision support</span>
      </div>
      <h1>UX Pattern Lab</h1>
      <p>{description}</p>
      <div class="pattern-hero-actions">
        <a class="primary-action" href={withBase("/patterns/")}>Browse directory</a>
        <a class="secondary-action" href={withBase("/compare/")}>Compare patterns</a>
      </div>
    </div>
    <aside class="source-method-panel">
      <h2>What to inspect</h2>
      <p>Use the lab for required states, keyboard behavior, live examples, failure modes, and alternatives when a static pattern page is not enough.</p>
    </aside>
  </header>

  <CatalogWorkbenchLoader
    client:load
    dataUrl={withBase("/lab-data.json")}
    baseUrl={withBase("/")}
    detailBaseUrl={withBase("/lab-patterns/")}
  />
</BaseLayout>
